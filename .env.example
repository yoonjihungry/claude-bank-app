# 이 파일은 커밋용 템플릿입니다. 실제 값은 .env.local(gitignore)에 넣으세요.
# .env.local 은 절대 커밋하지 않습니다.

# ── DB (Phase 6) ─────────────────────────────
# Vercel 대시보드 → Storage → Postgres 생성 후 나오는 연결 문자열을 .env.local 에 복사.
# Vercel Postgres는 보통 여러 변수를 주입합니다(POSTGRES_URL / POSTGRES_PRISMA_URL /
# POSTGRES_URL_NON_POOLING 등). Prisma가 사용할 값을 DATABASE_URL 로 지정하세요.
#   - 앱 쿼리용: 풀링된 URL(POSTGRES_PRISMA_URL 등)
#   - 마이그레이션: 논풀링(직접) URL 이 필요할 수 있음(POSTGRES_URL_NON_POOLING)
DATABASE_URL=

# ── 인증 (Phase 7 / Auth.js v5) ──────────
# Auth.js v5는 아래 이름 규칙을 자동 인식한다(NEXTAUTH_* 아님).
# AUTH_SECRET: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"` 로 생성
AUTH_SECRET=
# Google Cloud Console → OAuth 2.0 Client ID 발급 후 채운다.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# (선택) 커스텀 배포 도메인에서 콜백 URL 자동감지가 안 되면 지정: AUTH_URL=https://your-domain
